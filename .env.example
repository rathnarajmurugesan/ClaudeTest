# LLM Provider — set one of the following
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# LLM model to use for CrewAI agents (defaults to claude-sonnet-4-6 if ANTHROPIC_API_KEY is set)
# LLM_MODEL=claude-sonnet-4-6

# Optional: Serper API key for web search tool in the research agent
# SERPER_API_KEY=your_serper_api_key_here

# Set to "true" to use mock refinement (no LLM calls, useful for local dev)
MOCK_AGENT=false
